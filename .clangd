CompileFlags:
  CompilationDatabase: .
  # clang-cl 命令中的 /Fo、/Fd、/FS 在 clangd 改写后会报错
  Remove: [/Fo*, /Fd*, /FS]

Diagnostics:
  UnusedIncludes: Strict
  # MinGW/MSVC STL 下 include-cleaner 会把内部头
  # （yvals_core.h、__msvc_chrono.hpp 等）当成符号的直接提供者，
  # 产生大量不可移植的 missing-include 建议——关闭此诊断。
  MissingIncludes: None
