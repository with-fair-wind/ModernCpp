# Linux + GCC profile for ModernCpp.
#
# Pairs with the gcc-{debug,release,relwithdebinfo,minsizerel}-conan presets.
# Pinned to GCC 15 to match the CI baseline (ubuntu:25.10 container,
# default-apt g++-15). On older distros (Ubuntu 24.04 LTS still ships
# gcc-13) override on the CLI: `-s compiler.version=13`.
#
# Usage:
#   conan install . -pr=./conan/profiles/linux-gcc \
#       -s build_type=RelWithDebInfo \
#       --output-folder=build/gcc-relwithdebinfo-conan \
#       --build=missing

[settings]
os=Linux
arch=x86_64
compiler=gcc
compiler.version=15
compiler.cppstd=23
compiler.libcxx=libstdc++11
build_type=Release
