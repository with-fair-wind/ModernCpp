# Linux + Clang profile for ModernCpp.
#
# Pairs with the clang-{debug,release,relwithdebinfo,minsizerel}-conan presets.
# Pinned to Clang 20 to match the CI baseline (ubuntu:25.10 container,
# default-apt clang-20). Clang links against libstdc++ from g++-15 to get
# the C++23 stdlib (libc++ on apt still lags). Override compiler.version /
# libcxx if your host setup differs.
#
# Usage:
#   conan install . -pr=./conan/profiles/linux-clang \
#       -s build_type=RelWithDebInfo \
#       --output-folder=build/clang-relwithdebinfo-conan \
#       --build=missing

[settings]
os=Linux
arch=x86_64
compiler=clang
compiler.version=20
compiler.cppstd=23
compiler.libcxx=libstdc++11
build_type=Release
