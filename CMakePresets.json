{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "_base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },

        {
            "name": "_vcpkg",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        },

        {
            "name": "_conan",
            "hidden": true,
            "description": "Run `conan install . --output-folder=build/<preset> --build=missing` first; this preset then picks up the generated conan_toolchain.cmake.",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/${presetName}/conan_toolchain.cmake"
            }
        },

        {
            "name": "_gcc",
            "hidden": true,
            "inherits": ["_vcpkg", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "gcc-debug",          "displayName": "GCC Debug",
            "inherits": "_gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "gcc-release",        "displayName": "GCC Release",
            "inherits": "_gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "gcc-relwithdebinfo", "displayName": "GCC RelWithDebInfo",
            "inherits": "_gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "gcc-minsizerel",     "displayName": "GCC MinSizeRel",
            "inherits": "_gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "_clang",
            "hidden": true,
            "inherits": ["_vcpkg", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "condition": {
                "type": "anyOf",
                "conditions": [
                    { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
                    { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
                ]
            }
        },
        {
            "name": "clang-debug",          "displayName": "Clang Debug",
            "inherits": "_clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "clang-release",        "displayName": "Clang Release",
            "inherits": "_clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "clang-relwithdebinfo", "displayName": "Clang RelWithDebInfo",
            "inherits": "_clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "clang-minsizerel",     "displayName": "Clang MinSizeRel",
            "inherits": "_clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "msvc",
            "displayName": "MSVC (VS 2022, multi-config)",
            "description": "Visual Studio 17 2022 generator, x64. Pick Debug/Release/RelWithDebInfo/MinSizeRel at build time via --config.",
            "inherits": ["_vcpkg", "_base"],
            "generator": "Visual Studio 17 2022",
            "architecture": { "value": "x64", "strategy": "set" },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },

        {
            "name": "_clang-cl",
            "hidden": true,
            "description": "LLVM clang with the MSVC-compatible clang-cl driver. Requires running from a VS Developer Prompt so VS environment is available.",
            "inherits": ["_vcpkg", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl",
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "clang-cl-debug",          "displayName": "clang-cl Debug",
            "inherits": "_clang-cl", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "clang-cl-release",        "displayName": "clang-cl Release",
            "inherits": "_clang-cl", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "clang-cl-relwithdebinfo", "displayName": "clang-cl RelWithDebInfo",
            "inherits": "_clang-cl", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "clang-cl-minsizerel",     "displayName": "clang-cl MinSizeRel",
            "inherits": "_clang-cl", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "_mingw-gcc",
            "hidden": true,
            "description": "MinGW GCC (e.g. MSYS2 UCRT64). Run from the matching MSYS2 shell or with the ucrt64 bin dir on PATH.",
            "inherits": ["_vcpkg", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "mingw-gcc-debug",          "displayName": "MinGW GCC Debug",
            "inherits": "_mingw-gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "mingw-gcc-release",        "displayName": "MinGW GCC Release",
            "inherits": "_mingw-gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "mingw-gcc-relwithdebinfo", "displayName": "MinGW GCC RelWithDebInfo",
            "inherits": "_mingw-gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "mingw-gcc-minsizerel",     "displayName": "MinGW GCC MinSizeRel",
            "inherits": "_mingw-gcc", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "_mingw-clang",
            "hidden": true,
            "description": "MinGW Clang (e.g. MSYS2 UCRT64 clang++). Run from the matching MSYS2 shell or with the ucrt64 bin dir on PATH.",
            "inherits": ["_vcpkg", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "mingw-clang-debug",          "displayName": "MinGW Clang Debug",
            "inherits": "_mingw-clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "mingw-clang-release",        "displayName": "MinGW Clang Release",
            "inherits": "_mingw-clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "mingw-clang-relwithdebinfo", "displayName": "MinGW Clang RelWithDebInfo",
            "inherits": "_mingw-clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "mingw-clang-minsizerel",     "displayName": "MinGW Clang MinSizeRel",
            "inherits": "_mingw-clang", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "_gcc-conan",
            "hidden": true,
            "inherits": ["_conan", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "gcc-debug-conan",          "displayName": "GCC Debug (Conan)",
            "inherits": "_gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "gcc-release-conan",        "displayName": "GCC Release (Conan)",
            "inherits": "_gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "gcc-relwithdebinfo-conan", "displayName": "GCC RelWithDebInfo (Conan)",
            "inherits": "_gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "gcc-minsizerel-conan",     "displayName": "GCC MinSizeRel (Conan)",
            "inherits": "_gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "_clang-conan",
            "hidden": true,
            "inherits": ["_conan", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "condition": {
                "type": "anyOf",
                "conditions": [
                    { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
                    { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
                ]
            }
        },
        {
            "name": "clang-debug-conan",          "displayName": "Clang Debug (Conan)",
            "inherits": "_clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "clang-release-conan",        "displayName": "Clang Release (Conan)",
            "inherits": "_clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "clang-relwithdebinfo-conan", "displayName": "Clang RelWithDebInfo (Conan)",
            "inherits": "_clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "clang-minsizerel-conan",     "displayName": "Clang MinSizeRel (Conan)",
            "inherits": "_clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "msvc-conan",
            "displayName": "MSVC (VS 2022, Conan)",
            "description": "Visual Studio 17 2022 generator + Conan toolchain. Run `conan install . --output-folder=build/msvc-conan --build=missing` first.",
            "inherits": ["_conan", "_base"],
            "generator": "Visual Studio 17 2022",
            "architecture": { "value": "x64", "strategy": "set" },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },

        {
            "name": "_clang-cl-conan",
            "hidden": true,
            "description": "LLVM clang-cl + Conan toolchain. Requires running from a VS Developer Prompt.",
            "inherits": ["_conan", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "clang-cl",
                "CMAKE_CXX_COMPILER": "clang-cl"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "clang-cl-debug-conan",          "displayName": "clang-cl Debug (Conan)",
            "inherits": "_clang-cl-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "clang-cl-release-conan",        "displayName": "clang-cl Release (Conan)",
            "inherits": "_clang-cl-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "clang-cl-relwithdebinfo-conan", "displayName": "clang-cl RelWithDebInfo (Conan)",
            "inherits": "_clang-cl-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "clang-cl-minsizerel-conan",     "displayName": "clang-cl MinSizeRel (Conan)",
            "inherits": "_clang-cl-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "_mingw-gcc-conan",
            "hidden": true,
            "description": "MinGW GCC (e.g. MSYS2 UCRT64) + Conan toolchain.",
            "inherits": ["_conan", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "mingw-gcc-debug-conan",          "displayName": "MinGW GCC Debug (Conan)",
            "inherits": "_mingw-gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "mingw-gcc-release-conan",        "displayName": "MinGW GCC Release (Conan)",
            "inherits": "_mingw-gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "mingw-gcc-relwithdebinfo-conan", "displayName": "MinGW GCC RelWithDebInfo (Conan)",
            "inherits": "_mingw-gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "mingw-gcc-minsizerel-conan",     "displayName": "MinGW GCC MinSizeRel (Conan)",
            "inherits": "_mingw-gcc-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        },

        {
            "name": "_mingw-clang-conan",
            "hidden": true,
            "description": "MinGW Clang (e.g. MSYS2 UCRT64 clang++) + Conan toolchain.",
            "inherits": ["_conan", "_base"],
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "mingw-clang-debug-conan",          "displayName": "MinGW Clang Debug (Conan)",
            "inherits": "_mingw-clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "mingw-clang-release-conan",        "displayName": "MinGW Clang Release (Conan)",
            "inherits": "_mingw-clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
        },
        {
            "name": "mingw-clang-relwithdebinfo-conan", "displayName": "MinGW Clang RelWithDebInfo (Conan)",
            "inherits": "_mingw-clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
        },
        {
            "name": "mingw-clang-minsizerel-conan",     "displayName": "MinGW Clang MinSizeRel (Conan)",
            "inherits": "_mingw-clang-conan", "cacheVariables": { "CMAKE_BUILD_TYPE": "MinSizeRel" }
        }
    ],

    "buildPresets": [
        { "name": "gcc-debug",          "configurePreset": "gcc-debug" },
        { "name": "gcc-release",        "configurePreset": "gcc-release" },
        { "name": "gcc-relwithdebinfo", "configurePreset": "gcc-relwithdebinfo" },
        { "name": "gcc-minsizerel",     "configurePreset": "gcc-minsizerel" },

        { "name": "clang-debug",          "configurePreset": "clang-debug" },
        { "name": "clang-release",        "configurePreset": "clang-release" },
        { "name": "clang-relwithdebinfo", "configurePreset": "clang-relwithdebinfo" },
        { "name": "clang-minsizerel",     "configurePreset": "clang-minsizerel" },

        { "name": "msvc-debug",          "configurePreset": "msvc", "configuration": "Debug" },
        { "name": "msvc-release",        "configurePreset": "msvc", "configuration": "Release" },
        { "name": "msvc-relwithdebinfo", "configurePreset": "msvc", "configuration": "RelWithDebInfo" },
        { "name": "msvc-minsizerel",     "configurePreset": "msvc", "configuration": "MinSizeRel" },

        { "name": "clang-cl-debug",          "configurePreset": "clang-cl-debug" },
        { "name": "clang-cl-release",        "configurePreset": "clang-cl-release" },
        { "name": "clang-cl-relwithdebinfo", "configurePreset": "clang-cl-relwithdebinfo" },
        { "name": "clang-cl-minsizerel",     "configurePreset": "clang-cl-minsizerel" },

        { "name": "mingw-gcc-debug",          "configurePreset": "mingw-gcc-debug" },
        { "name": "mingw-gcc-release",        "configurePreset": "mingw-gcc-release" },
        { "name": "mingw-gcc-relwithdebinfo", "configurePreset": "mingw-gcc-relwithdebinfo" },
        { "name": "mingw-gcc-minsizerel",     "configurePreset": "mingw-gcc-minsizerel" },

        { "name": "mingw-clang-debug",          "configurePreset": "mingw-clang-debug" },
        { "name": "mingw-clang-release",        "configurePreset": "mingw-clang-release" },
        { "name": "mingw-clang-relwithdebinfo", "configurePreset": "mingw-clang-relwithdebinfo" },
        { "name": "mingw-clang-minsizerel",     "configurePreset": "mingw-clang-minsizerel" },

        { "name": "gcc-debug-conan",            "configurePreset": "gcc-debug-conan" },
        { "name": "gcc-release-conan",          "configurePreset": "gcc-release-conan" },
        { "name": "gcc-relwithdebinfo-conan",   "configurePreset": "gcc-relwithdebinfo-conan" },
        { "name": "gcc-minsizerel-conan",       "configurePreset": "gcc-minsizerel-conan" },

        { "name": "clang-debug-conan",          "configurePreset": "clang-debug-conan" },
        { "name": "clang-release-conan",        "configurePreset": "clang-release-conan" },
        { "name": "clang-relwithdebinfo-conan", "configurePreset": "clang-relwithdebinfo-conan" },
        { "name": "clang-minsizerel-conan",     "configurePreset": "clang-minsizerel-conan" },

        { "name": "msvc-debug-conan",          "configurePreset": "msvc-conan", "configuration": "Debug" },
        { "name": "msvc-release-conan",        "configurePreset": "msvc-conan", "configuration": "Release" },
        { "name": "msvc-relwithdebinfo-conan", "configurePreset": "msvc-conan", "configuration": "RelWithDebInfo" },
        { "name": "msvc-minsizerel-conan",     "configurePreset": "msvc-conan", "configuration": "MinSizeRel" },

        { "name": "clang-cl-debug-conan",          "configurePreset": "clang-cl-debug-conan" },
        { "name": "clang-cl-release-conan",        "configurePreset": "clang-cl-release-conan" },
        { "name": "clang-cl-relwithdebinfo-conan", "configurePreset": "clang-cl-relwithdebinfo-conan" },
        { "name": "clang-cl-minsizerel-conan",     "configurePreset": "clang-cl-minsizerel-conan" },

        { "name": "mingw-gcc-debug-conan",          "configurePreset": "mingw-gcc-debug-conan" },
        { "name": "mingw-gcc-release-conan",        "configurePreset": "mingw-gcc-release-conan" },
        { "name": "mingw-gcc-relwithdebinfo-conan", "configurePreset": "mingw-gcc-relwithdebinfo-conan" },
        { "name": "mingw-gcc-minsizerel-conan",     "configurePreset": "mingw-gcc-minsizerel-conan" },

        { "name": "mingw-clang-debug-conan",          "configurePreset": "mingw-clang-debug-conan" },
        { "name": "mingw-clang-release-conan",        "configurePreset": "mingw-clang-release-conan" },
        { "name": "mingw-clang-relwithdebinfo-conan", "configurePreset": "mingw-clang-relwithdebinfo-conan" },
        { "name": "mingw-clang-minsizerel-conan",     "configurePreset": "mingw-clang-minsizerel-conan" }
    ],

    "testPresets": [
        {
            "name": "_test-base",
            "hidden": true,
            "output": { "outputOnFailure": true, "shortProgress": true },
            "execution": { "noTestsAction": "ignore", "stopOnFailure": false }
        },

        { "name": "gcc-debug",          "inherits": "_test-base", "configurePreset": "gcc-debug" },
        { "name": "gcc-release",        "inherits": "_test-base", "configurePreset": "gcc-release" },
        { "name": "gcc-relwithdebinfo", "inherits": "_test-base", "configurePreset": "gcc-relwithdebinfo" },
        { "name": "gcc-minsizerel",     "inherits": "_test-base", "configurePreset": "gcc-minsizerel" },

        { "name": "clang-debug",          "inherits": "_test-base", "configurePreset": "clang-debug" },
        { "name": "clang-release",        "inherits": "_test-base", "configurePreset": "clang-release" },
        { "name": "clang-relwithdebinfo", "inherits": "_test-base", "configurePreset": "clang-relwithdebinfo" },
        { "name": "clang-minsizerel",     "inherits": "_test-base", "configurePreset": "clang-minsizerel" },

        { "name": "msvc-debug",          "inherits": "_test-base", "configurePreset": "msvc", "configuration": "Debug" },
        { "name": "msvc-release",        "inherits": "_test-base", "configurePreset": "msvc", "configuration": "Release" },
        { "name": "msvc-relwithdebinfo", "inherits": "_test-base", "configurePreset": "msvc", "configuration": "RelWithDebInfo" },
        { "name": "msvc-minsizerel",     "inherits": "_test-base", "configurePreset": "msvc", "configuration": "MinSizeRel" },

        { "name": "clang-cl-debug",          "inherits": "_test-base", "configurePreset": "clang-cl-debug" },
        { "name": "clang-cl-release",        "inherits": "_test-base", "configurePreset": "clang-cl-release" },
        { "name": "clang-cl-relwithdebinfo", "inherits": "_test-base", "configurePreset": "clang-cl-relwithdebinfo" },
        { "name": "clang-cl-minsizerel",     "inherits": "_test-base", "configurePreset": "clang-cl-minsizerel" },

        { "name": "mingw-gcc-debug",          "inherits": "_test-base", "configurePreset": "mingw-gcc-debug" },
        { "name": "mingw-gcc-release",        "inherits": "_test-base", "configurePreset": "mingw-gcc-release" },
        { "name": "mingw-gcc-relwithdebinfo", "inherits": "_test-base", "configurePreset": "mingw-gcc-relwithdebinfo" },
        { "name": "mingw-gcc-minsizerel",     "inherits": "_test-base", "configurePreset": "mingw-gcc-minsizerel" },

        { "name": "mingw-clang-debug",          "inherits": "_test-base", "configurePreset": "mingw-clang-debug" },
        { "name": "mingw-clang-release",        "inherits": "_test-base", "configurePreset": "mingw-clang-release" },
        { "name": "mingw-clang-relwithdebinfo", "inherits": "_test-base", "configurePreset": "mingw-clang-relwithdebinfo" },
        { "name": "mingw-clang-minsizerel",     "inherits": "_test-base", "configurePreset": "mingw-clang-minsizerel" },

        { "name": "gcc-debug-conan",          "inherits": "_test-base", "configurePreset": "gcc-debug-conan" },
        { "name": "gcc-release-conan",        "inherits": "_test-base", "configurePreset": "gcc-release-conan" },
